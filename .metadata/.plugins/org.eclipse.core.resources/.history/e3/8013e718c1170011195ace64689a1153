package com.nt.service;

import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.nt.entity.Customer;
import com.nt.repository.ICustomerRepository;

@Service
public class CustomerServiceImpl implements ICustomerService {
	
	@Autowired
	private ICustomerRepository custRepo;

	@Override
	public String createCustomer(Customer customer) {
		custRepo.save(customer);
		return "Customer saved with "+customer.getId()+" as there customerId";
	}

	@Override
	public List<Customer> getAllCustomers() {
		List<Customer> customers=custRepo.findAll();
		if(customers.isEmpty()) {
			throw new RuntimeException("No Customers Found"); 
		}else {
			return customers;
		}
	}

	@Override
	public Customer getCustomerById(Long id) {
		Optional<Customer> cust=custRepo.findById(id);
		if(cust.isPresent()) {
			return cust.get();
		}else {
			throw new RuntimeException("No Customers Found"); 
		}
	}

	@Override
	public Customer updateCustomer(Long id, Customer customer) {
		Optional<Customer> cust=custRepo.findById(id);
		if(cust.isPresent()) {
			Customer cust1=cust.get();
			cust1.setFirstName(customer.getFirstName());
			cust1.setLastName(customer.getLastName());
			cust1.setEmail(customer.getEmail());
			cust1.setPhoneNumber(customer.getPhoneNumber());
			custRepo.save(cust1);
			return cust1;
		}
	}

	@Override
	public String deleteCustomerById(Long id) {
		// TODO Auto-generated method stub
		return null;
	}

	
}
