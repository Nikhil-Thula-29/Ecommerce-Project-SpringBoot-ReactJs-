package com.nt.service;

import java.util.ArrayList;
import java.util.List;
import java.util.function.Predicate;

import org.springframework.stereotype.Service;

import com.nt.model.Category;


@Service
public class CategoryService implements ICategoryService {

	private List<Category> cat=new ArrayList<Category>(); 
	private Long catId=1L;
	
	@Override
	public List<Category> getAllCategories() {
		return cat;
	}

	@Override
	public void createCategory(Category category) {
		category.setCategoryId(catId++);
		cat.add(category);
	}

	@Override
	public String deleteCategory(Long categoryId) {
		Predicate<Category> predicate=new Predicate<Category>() {
			
			@Override
			public boolean test(Category t) {
				return t.getCategoryId().equals(categoryId);
			}
		};
		Category category=cat.stream().filter(predicate).findFirst().get();
		cat.remove(category);
		return categoryId+" deleted successfully";
	}
	
	
}
